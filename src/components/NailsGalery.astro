---
import { Image } from "astro:assets";

// Importaciones (Recuerda importar las 24 fotos reales)
const images = import.meta.glob("../assets/nails/*.webp", { eager: true });

// Forzamos a que galeriaNails sea un array de objetos de imagen de Astro
const galeriaNails = Object.values(images).map((img: any) => img.default);
---

<div class="grid grid-cols-2 md:grid-cols-3 gap-4">
    {
        galeriaNails.map((foto, index) => (
            <div class="overflow-hidden rounded-[20px] shadow-lg border border-white/5 group">
                <Image
                    src={foto}
                    alt={`Diseño de uñas - Estética SandraMZCórdoba en Logroño ${index + 1}`}
                    width={600}
                    height={600}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                />
            </div>
        ))
    }
</div>
