---
import MapIcon from "./MapIcon.astro";
import WhatsappIcon from "./WhatsappIcon.astro";
import Map from "./Map.astro";
---

<section
    id="contacto"
    class="mt-20 w-full grid grid-cols-1 md:grid-cols-2 gap-8 items-stretch"
>
    <div
        class="bg-white/10 backdrop-blur-xl rounded-[40px] p-8 md:p-10 border-[#cdb4db] border-2 shadow-2xl flex flex-col justify-center"
    >
        <h3 class="text-3xl font-bold text-[#45556c] mb-6">¿Tienes dudas?</h3>
        <p class="text-slate-400 mb-8 italic">
            Reserva tu cita por teléfono o ven a visitarnos a nuestro centro.
        </p>

        <div class="space-y-6">
            <div class="flex items-center gap-4 group">
                <div
                    class="size-12 rounded-full bg-[#CDB4DB]/20 flex items-center justify-center text-[#45556c]"
                >
                    <MapIcon />
                </div>
                <div>
                    <p class="text-[#45556c] font-bold">Dirección</p>
                    <p class="text-slate-400">Calle Vélez de Guevara, 30, Logroño</p>
                </div>
            </div>

            <div class="flex items-center gap-4 group">
                <div
                    class="size-12 rounded-full bg-[#CDB4DB]/20 flex items-center justify-center text-[#45556c]"
                >
                    <WhatsappIcon />
                </div>
                <div>
                    <p class="text-[#45556c] font-bold">WhatsApp</p>
                    <p class="text-slate-400">+34 638610289</p>
                </div>
            </div>
        </div>

        <div
            class="flex flex-col sm:flex-row gap-4 mt-10 w-full justify-center md:justify-start"
        >
            <a
                href="https://wa.me/34638610289"
                class="flex-1 bg-[#25D366] text-white text-center py-4 px-8 rounded-full font-bold hover:scale-105 transition-all shadow-lg whitespace-nowrap"
            >
                Hablar por WhatsApp
            </a>

            <a
                href="tel:+34638610289"
                class="flex-1 bg-[#CDB4DB] text-white text-center py-4 px-8 rounded-full font-bold hover:scale-105 transition-all shadow-lg whitespace-nowrap"
            >
                Llamar por teléfono
            </a>
        </div>
    </div>

    <div
        class="rounded-[40px] overflow-hidden border-[#cdb4db] border-2 shadow-2xl min-h-100"
    >
        <Map/>
    </div>
</section>
