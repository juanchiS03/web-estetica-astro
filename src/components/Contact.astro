---
import Map from "./Map.astro";
import DataCard from "./DataCard.astro";
---

<section
    id="contacto"
    class="mt-20 w-full grid grid-cols-1 md:grid-cols-2 gap-8 items-stretch"
>
    <DataCard />

    <div
        class="rounded-[40px] overflow-hidden border-[#cdb4db] border-2 shadow-2xl min-h-100"
    >
        <Map/>
    </div>
</section>
