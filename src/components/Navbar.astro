                    Estética <span class="text-slate-400">SandraMzCórdoba</span>
                </h1>
            </a>
        </div>

        <div class="flex justify-center items-center gap-x-5 text-[11px] sm:text-xs font-semibold uppercase tracking-widest text-[#CDB4DB]">
            <a href="/#inicio" class="active:text-white">Inicio</a>
            <a href="/#servicios" class="active:text-white">Servicios</a>
