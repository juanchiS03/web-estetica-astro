---
import Layout from "../../layouts/Layout.astro";
import { serviciosData } from "../../data/servicios.js";

export function getStaticPaths() {
    return serviciosData.map((s) => ({
        params: { servicios: s.slug },
        props: { info: s },
    }));
}

const { info } = Astro.props;
---

<Layout title={`${info.titulo} - Estética SandraMZCórdoba`}>
    <div
        class="fixed inset-0 -z-10 h-full w-full [background:radial-gradient(125%_100%_at_50%_10%,#000_40%,#CDB4DB_100%)]"
    >
    </div>

    <main
        class="relative pt-40 pb-20 px-6 max-w-4xl mx-auto min-h-screen flex flex-col items-center"
    >
        <div class="text-center mb-16">
            <h1
                class="text-5xl md:text-7xl font-bold text-white tracking-tighter"
            >
                {info.titulo.split(" ")[0]}
                <span class="text-[#CDB4DB]"
                    >{info.titulo.split(" ").slice(1).join(" ")}</span
                >
            </h1>
            <p class="mt-4 text-slate-400 text-lg max-w-xl mx-auto">
                {info.descripcion}
            </p>
        </div>

        <div class="w-full backdrop-blur-xl p-8 md:p-16 rounded-4xl">
            <h3
                class="text-3xl font-bold text-white mb-12 flex items-center gap-2"
            >
                <span class="text-[#CDB4DB]">✦</span> Tarifas de Servicio
            </h3>

            <div class="flex flex-col w-full gap-y-12 mb-16">
                {
                    info.precios.map((item) => (
                        <div class="flex items-start justify-between w-full group gap-x-4">
                            <div class="flex-1 min-w-0">
                                <p class="text-xl md:text-2xl font-bold text-white wrap-break-word [hyphens:auto] [lang:es]">
                                    {item.nombre}
                                </p>
                                <p class="text-slate-400 mt-1 text-sm md:text-lg italic leading-relaxed">
                                    {item.detalle}
                                </p>
                            </div>

                            <div class="text-2xl md:text-3xl font-extrabold text-[#CDB4DB] whitespace-nowrap pt-1">
                                {item.precio}
                            </div>
                        </div>
                    ))
                }
            </div>

            <div class="mt-16 text-center">
                <a
                    href="/#contacto"
                    class="inline-block bg-[#CDB4DB] text-white px-12 py-5 rounded-full font-bold hover:scale-105 transition-all shadow-xl active:scale-95 text-xl"
                >
                    Reservar Cita
                </a>
            </div>
        </div>

        <div class="mt-12 text-center flex justify-center">
            <a
                href="/#servicios"
                data-astro-prefetch
                class="group flex items-center gap-1 text-[#CDB4DB] hover:text-[#a96fcb] transition-all cursor-pointer font-medium group-hover:gap-3"
            >
                <span class="text-lg">←</span> Volver a la página principal
            </a>
        </div>
    </main>
</Layout>
