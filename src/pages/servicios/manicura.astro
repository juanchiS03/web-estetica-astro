---
import NailsGalery from "../../components/NailsGalery.astro";
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Manicura Premium - Estética SandraMZCórdoba">
  <div
    class="relative min-h-screen w-full [background:radial-gradient(125%_100%_at_50%_10%,#000_40%,#CDB4DB_100%)]"
  >
    <main class="max-w-full mx-auto pt-40 pb-20 px-6">
      <h1 class="text-5xl md:text-7xl font-bold text-white tracking-tighter mb-10 text-center">
        Manicura <span class="text-[#CDB4DB]">Premium</span>
      </h1>

      <NailsGalery />

      <div class="flex justify-center w-full mt-10">
        <a
          href="/#servicios"
          data-astro-prefetch
          class="flex items-center text-white hover:text-[#CDB4DB] font-bold transition-colors"
        >
          <span class="mr-2">←</span> Volver al inicio
        </a>
      </div>
    </main>
  </div>
</Layout>
