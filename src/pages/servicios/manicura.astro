---
import Layout from "../../layouts/Layout.astro";
---

<Layout>
  <div
    class="absolute inset-0 -z-10 h-full w-full items-center px-5 py-24 [background:radial-gradient(125%_100%_at_50%_10%,#000_40%,#CDB4DB_100%)]"
  >
  </div>
  <main class="max-w-4xl mx-auto pt-40 pb-20 px-6">
    <h1 class="text-4xl font-bold text-[#90a1b9]">Manicura Premium</h1>
    <p class="mt-6 text-lg text-slate-500">
      Aquí explicas detalladamente en qué consiste el servicio, precios,
      duración, etc.
    </p>
    <a
      href="/#servicios"
      data-astro-prefetch
      class="mt-10 inline-block text-[#CDB4DB] hover:text-[#a96fcb] font-bold"
      >← Volver al inicio</a
    >
  </main>
</Layout>
